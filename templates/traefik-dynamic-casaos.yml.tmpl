# Generated by nullwatch. Traefik's file provider watches this directory —
# changes take effect without restarting the container. Routes
# casaos.{{.Domain}} to CasaOS, a native process on the host rather than a
# container on nullwatch-net, reached via the Docker bridge gateway address.
# The bare domain redirects to casaos.{{.Domain}} rather than serving CasaOS
# directly, so the browser's address bar always reflects the actual route —
# useful if the root ever points somewhere else later.
http:
  middlewares:
    casaos-redirect:
      redirectRegex:
        regex: "^http://[^/]+(.*)"
        replacement: "http://casaos.{{.Domain}}${1}"
        permanent: false
  routers:
    casaos:
      rule: "Host(`casaos.{{.Domain}}`)"
      entryPoints:
        - web
      service: casaos
    casaos-root:
      rule: "Host(`{{.Domain}}`)"
      entryPoints:
        - web
      middlewares:
        - casaos-redirect
      service: casaos
  services:
    casaos:
      loadBalancer:
        servers:
          - url: "http://{{.CasaOSGatewayIP}}:{{.CasaOSPort}}"
