# Generated by nullwatch. Safe to run by hand:
#   docker compose -f adguard.yml -p nullwatch-adguard up -d
services:
  adguard:
    image: {{.Image}}
    container_name: nullwatch-adguard
    restart: unless-stopped
    ports:
      - "{{.HTTPPort}}:{{.HTTPPort}}/tcp"
      - "{{.DNSPort}}:{{.DNSPort}}/tcp"
      - "{{.DNSPort}}:{{.DNSPort}}/udp"
    volumes:
      - "{{.ConfDir}}:/opt/adguardhome/conf"
      - "{{.WorkDir}}:/opt/adguardhome/work"
    networks:
      nullwatch-net:
        ipv4_address: {{.StaticIP}}

networks:
  nullwatch-net:
    name: {{.NetworkName}}
    external: true
