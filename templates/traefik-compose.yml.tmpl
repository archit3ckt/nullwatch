# Generated by nullwatch. Safe to run by hand:
#   docker compose -f traefik.yml -p nullwatch-traefik up -d
#
# Nothing here is meant to be reachable from the public internet — see
# internal/firewall, which restricts every port except the WireGuard tunnel
# to the VPN subnet and localhost. TLS uses Traefik's own self-signed
# certificate (no ACME/Let's Encrypt, since HTTP-01 needs port 80 reachable
# from the internet, which it deliberately isn't here).
services:
  traefik:
    image: {{.Image}}
    container_name: nullwatch-traefik
    restart: unless-stopped
    command:
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.file.directory=/etc/traefik/dynamic
      - --providers.file.watch=true
      - --entrypoints.web.address=:80
      - --entrypoints.websecure.address=:443
      - --entrypoints.web.http.redirections.entrypoint.to=websecure
      - --entrypoints.web.http.redirections.entrypoint.scheme=https
{{- if .DashboardEnabled}}
      - --api.dashboard=true
      - --api.insecure=true
{{- end}}
    ports:
      - "{{.HTTPPort}}:80/tcp"
      - "{{.HTTPSPort}}:443/tcp"
{{- if .DashboardEnabled}}
      - "{{.DashboardPort}}:8080/tcp"
{{- end}}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - "{{.DynamicDir}}:/etc/traefik/dynamic"
    networks:
      nullwatch-net:
        ipv4_address: {{.StaticIP}}

networks:
  nullwatch-net:
    name: {{.NetworkName}}
    external: true

# Traefik is also attached to Docker's default "bridge" network, so it can
# reach CasaOS apps (most of which land there via network_mode: bridge) by
# their own container IP + internal port — confirmed on a real deployment
# that going through the host's gateway address instead (the same way
# CasaOS itself is reached, since that's a plain native process with no NAT
# involved) times out for anything docker-proxy publishes: a container on
# one bridge reaching a docker-proxy'd port via another bridge's gateway is
# a known Docker hairpin-NAT gap, not fixable from nullwatch's side.
#
# That attachment is deliberately NOT declared here in compose's own
# networks: block — doing so hits a real Docker limitation ("network-scoped
# aliases are only supported for user-defined networks"), since compose
# always tries to register container_name as an alias on every network a
# service joins, and the classic bridge network can't support aliases at
# all. internal/modules/traefik.PostApply instead runs a plain `docker
# network connect bridge nullwatch-traefik` after compose brings the
# container up, which doesn't go through that alias logic.
