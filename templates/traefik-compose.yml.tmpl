# Generated by nullwatch. Safe to run by hand:
#   docker compose -f traefik.yml -p nullwatch-traefik up -d
#
# Dashboard (if enabled) is exposed without its own auth — it's meant to be
# reached only over the WireGuard tunnel, not the public internet. Don't
# port-forward {{.DashboardPort}} on your router/firewall.
services:
  traefik:
    image: {{.Image}}
    container_name: nullwatch-traefik
    restart: unless-stopped
    command:
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.file.directory=/etc/traefik/dynamic
      - --providers.file.watch=true
      - --entrypoints.web.address=:80
      - --entrypoints.websecure.address=:443
      - --entrypoints.web.http.redirections.entrypoint.to=websecure
      - --entrypoints.web.http.redirections.entrypoint.scheme=https
      - --certificatesresolvers.letsencrypt.acme.email={{.ACMEEmail}}
      - --certificatesresolvers.letsencrypt.acme.storage=/etc/traefik/acme.json
      - --certificatesresolvers.letsencrypt.acme.httpchallenge=true
      - --certificatesresolvers.letsencrypt.acme.httpchallenge.entrypoint=web
{{- if .DashboardEnabled}}
      - --api.dashboard=true
      - --api.insecure=true
{{- end}}
    ports:
      - "{{.HTTPPort}}:80/tcp"
      - "{{.HTTPSPort}}:443/tcp"
{{- if .DashboardEnabled}}
      - "{{.DashboardPort}}:8080/tcp"
{{- end}}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - "{{.DynamicDir}}:/etc/traefik/dynamic"
      - "{{.DataDir}}/acme.json:/etc/traefik/acme.json"
    networks:
      nullwatch-net:
        ipv4_address: {{.StaticIP}}

networks:
  nullwatch-net:
    name: {{.NetworkName}}
    external: true
