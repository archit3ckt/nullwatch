# Generated by nullwatch. Safe to run by hand:
#   docker compose -f traefik.yml -p nullwatch-traefik up -d
#
# Nothing here is meant to be reachable from the public internet — see
# internal/firewall, which restricts every port except the WireGuard tunnel
# to the VPN subnet and localhost. TLS uses Traefik's own self-signed
# certificate (no ACME/Let's Encrypt, since HTTP-01 needs port 80 reachable
# from the internet, which it deliberately isn't here).
services:
  traefik:
    image: {{.Image}}
    container_name: nullwatch-traefik
    restart: unless-stopped
    command:
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.file.directory=/etc/traefik/dynamic
      - --providers.file.watch=true
      - --entrypoints.web.address=:80
      - --entrypoints.websecure.address=:443
      - --entrypoints.web.http.redirections.entrypoint.to=websecure
      - --entrypoints.web.http.redirections.entrypoint.scheme=https
{{- if .DashboardEnabled}}
      - --api.dashboard=true
      - --api.insecure=true
{{- end}}
    ports:
      - "{{.HTTPPort}}:80/tcp"
      - "{{.HTTPSPort}}:443/tcp"
{{- if .DashboardEnabled}}
      - "{{.DashboardPort}}:8080/tcp"
{{- end}}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - "{{.DynamicDir}}:/etc/traefik/dynamic"
    networks:
      nullwatch-net:
        ipv4_address: {{.StaticIP}}

networks:
  nullwatch-net:
    name: {{.NetworkName}}
    external: true
