# Generated by nullwatch. Safe to run by hand:
#   docker compose -f wireguard.yml -p nullwatch-wireguard up -d
services:
  wg-easy:
    image: {{.Image}}
    container_name: nullwatch-wireguard
    restart: unless-stopped
    environment:
      - WG_HOST={{.Host}}
      - WG_PORT={{.Port}}
      - WG_DEFAULT_ADDRESS={{.DefaultAddr}}
      - WG_DEFAULT_DNS={{.DNS}}
      - PASSWORD={{.Password}}
      - PORT={{.WebUIPort}}
    volumes:
      - "{{.DataDir}}:/etc/wireguard"
    ports:
      - "{{.Port}}:{{.Port}}/udp"
      - "{{.WebUIPort}}:{{.WebUIPort}}/tcp"
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
    networks:
      nullwatch-net:
        ipv4_address: {{.StaticIP}}

networks:
  nullwatch-net:
    name: {{.NetworkName}}
    external: true
