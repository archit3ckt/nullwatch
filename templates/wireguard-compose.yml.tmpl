# Generated by nullwatch. Safe to run by hand:
#   docker compose -f wireguard.yml -p nullwatch-wireguard up -d
#
# WG_ALLOWED_IPS is IPv4-only on purpose: nullwatch-net has no IPv6
# configured, so wg-easy's own default of "0.0.0.0/0, ::/0" routes IPv6
# traffic into a container with no IPv6 route at all. That doesn't fail
# fast (no ICMP unreachable makes it back through the tunnel) — it just
# hangs, which on a device that prefers IPv6 (most phones) looks exactly
# like "connected to the VPN but can't browse". Dropping ::/0 lets IPv6
# traffic go out the client's own connection instead of into a black hole.
services:
  wg-easy:
    image: {{.Image}}
    container_name: nullwatch-wireguard
    restart: unless-stopped
    environment:
      - WG_HOST={{.Host}}
      - WG_PORT={{.Port}}
      - WG_DEFAULT_ADDRESS={{.DefaultAddr}}
      - WG_DEFAULT_DNS={{.DNS}}
      - WG_ALLOWED_IPS=0.0.0.0/0
      - PASSWORD={{.Password}}
      - PORT={{.WebUIPort}}
    volumes:
      - "{{.DataDir}}:/etc/wireguard"
    ports:
      - "{{.Port}}:{{.Port}}/udp"
      - "{{.WebUIPort}}:{{.WebUIPort}}/tcp"
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
    networks:
      nullwatch-net:
        ipv4_address: {{.StaticIP}}

networks:
  nullwatch-net:
    name: {{.NetworkName}}
    external: true
